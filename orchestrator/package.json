{
  "name": "veriaudit-orchestrator",
  "version": "0.1.0",
  "private": true,
  "description": "TS orchestration layer for VeriAudit: API, EIP-712 signing, on-chain attestation. Python survives only as the AI worker.",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "ethers": "^6.13.0",
    "fastify": "^5.0.0",
    "@fastify/cors": "^10.0.0",
    "viem": "^2.21.0",
    "zod": "^3.23.0",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
