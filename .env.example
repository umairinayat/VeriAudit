# ---- Blockchain (Pillar A) ----
# RPC endpoint for the target network. For local dev use Anvil (http://127.0.0.1:8545).
RPC_URL=http://127.0.0.1:8545
SEPOLIA_RPC_URL=
# Chain id: 31337 = local Anvil, 11155111 = Sepolia.
CHAIN_ID=31337
# Deployer key (used by `forge script` deploy). NEVER commit a real key.
# Anvil prints 10 test keys on start; account 0 is 0xac0974...
PRIVATE_KEY=
# Address of the deployed AuditRegistry contract (filled after deploy).
AUDIT_REGISTRY_ADDRESS=

# ---- Orchestrator (Pillar A client + API, TypeScript) ----
# Auditor = the account that signs EIP-712 attestations and submits recordAudit.
# MUST be registered on-chain (registerAuditor with minStake ETH).
# Anvil account 1 = 0x59c6995e... → address 0x70997970C51812dc3A010C7d01b50e0d17dc79C8
AUDITOR_PRIVATE_KEY=
AUDITOR_ADDRESS=
ORCH_PORT=8000
# Worker URL (the Python AI worker on :8001).
WORKER_URL=http://127.0.0.1:8001
# SECURITY: bearer token required on POST /audit and POST /attest. If unset the
# server runs in permissive DEV mode (anyone can trigger on-chain attests with
# the auditor key). ALWAYS set this in any real deployment.
ORCH_API_KEY=
# SECURITY: comma-separated CORS origin allowlist. Empty = allow all (dev only).
ORCH_CORS_ORIGINS=

# ---- AI worker (Pillar B, the ONLY Python) ----
# Which LLM provider the detection layer uses. Default "mock" = deterministic stub.
LLM_PROVIDER=mock
# Used only when LLM_PROVIDER is a real provider.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
LLM_MODEL=
# Optional: override the dir the worker searches for vendored forge-std (PoC harness).
VERIAUDIT_FORGE_LIB=

# ---- Off-chain storage (report bundles) ----
# IPFS pinning API (empty = no pinning; full bundle still on-chain via events).
IPFS_API=
REPORT_STORAGE=./.reports

# ---- Frontend (Vite, optional overrides) ----
VITE_CHAIN_ID=31337
VITE_REGISTRY_ADDRESS=
VITE_RPC_URL=http://127.0.0.1:8545

# ---- Block explorer (optional) ----
ETHERSCAN_API_KEY=
